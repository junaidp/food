# Database
DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=3001
NODE_ENV=development

# SMS Provider: 'easysend' | 'twilio' | 'dev'
SMS_PROVIDER=easysend

# EasySendSMS (RapidAPI) - Primary SMS provider
RAPIDAPI_KEY=your-rapidapi-key
EASYSEND_USERNAME=your-easysend-username
EASYSEND_PASSWORD=your-easysend-password
EASYSEND_FROM=FoodShare

# Twilio (Fallback) - Get credentials from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid
